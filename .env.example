# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=file:./dev.db
# Public shared testing should use Postgres instead:
# DATABASE_URL=postgresql://vera:password@host:5432/vera?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Local debugging only. Keep false in deployed environments.
ALLOW_DEMO_HEADER=false

# Storage
STORAGE_ADAPTER=local
ACCEPT_LOCAL_STORAGE_IN_PRODUCTION=false
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:4000
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# AI
# mock: deterministic local extraction; gemini: Gemini API transcription/extraction.
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Iiko
# mock: safe local/demo mode; real: performs real iikoCloud auth/test requests.
IIKO_ADAPTER=mock
IIKO_BASE_URL=https://api-ru.iiko.services
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
